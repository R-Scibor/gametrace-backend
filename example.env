POSTGRES_USER=gametrace_user
POSTGRES_PASSWORD=gametrace_pass
POSTGRES_DB=gametrace_db
DATABASE_URL=postgresql+asyncpg://gametrace_user:gametrace_pass@db:5432/gametrace_db
REDIS_URL=redis://redis:6379/0

# Discord
DISCORD_BOT_TOKEN=your_discord_bot_token

# Voice pipeline — OpenAI Whisper (STT) + Vertex AI Gemini Flash (text→JSON)
OPENAI_API_KEY=your_openai_api_key
GCP_PROJECT=your-gcp-project
GCP_LOCATION=us-central1
# Service-account JSON for Vertex AI ADC. Mount the file into the api container
# (see docker-compose.yml) and set the path to where it lands inside the container.
# GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/gcp-sa.json

# Game enrichment — IGDB via Twitch OAuth (Client ID + Secret from the Twitch dev console)
IGDB_CLIENT_ID=your_twitch_client_id
IGDB_CLIENT_SECRET=your_twitch_client_secret

# Firebase Cloud Messaging — service-account JSON for push notifications.
# File is mounted into api/worker/beat at /app/credentials/firebase-cred.json.
FIREBASE_CREDENTIALS_PATH=/app/credentials/firebase-cred.json

# Auth — sliding-window session token lifetime (days). Default 30.
SESSION_TOKEN_EXPIRE_DAYS=30

# Observability — Sentry (optional, leave blank to disable)
SENTRY_DSN=
SENTRY_ENVIRONMENT=homelab

# Flower (Celery monitor) — basic auth in user:pass form. Leave blank to disable auth.
# Flower has no read-only mode; never expose without auth on a public host.
FLOWER_BASIC_AUTH=
